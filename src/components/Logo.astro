---
import { SITE } from 'astrowind:config';
---

<a href="/" class="flex items-center gap-2 group" aria-label={`${SITE?.name} home`}>
  <span
    class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gradient-to-br from-sky-500 to-blue-600 text-white font-black text-lg shadow-sm group-hover:shadow-md transition-shadow"
    aria-hidden="true"
  >
    F
  </span>
  <span
    class="self-center text-xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white tracking-tight"
  >
    {SITE?.name}
  </span>
</a>
