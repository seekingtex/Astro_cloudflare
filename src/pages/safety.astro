---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { products } from '../data/products';

const metadata = {
  title: `Safety — ${SITE.name}`,
  description: 'Wavefella safety standards: CE certification, ISO 12402, SOLAS compliance, pressure and buoyancy testing, and product safety guidelines.',
};
const safetyProducts = products.filter(p => p.category === 'SAFETY');
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="water-safety-equipment,ce-certified-life-vests,marine-safety-standards" />

  <section class="max-w-4xl mx-auto py-24 px-6" data-ai-block="definition">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Safety</span>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">Safety Standards & Certification</h1>
    <p class="mt-4 text-lg text-gray-500">Every Wavefella product undergoes rigorous testing and meets international safety standards for recreational and professional use.</p>
  </section>

  <section class="max-w-4xl mx-auto pb-24 px-6">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-white border border-gray-200 rounded-2xl p-6">
        <h2 class="text-lg font-semibold text-gray-900">CE Certification</h2>
        <p class="mt-2 text-sm text-gray-600">All Wavefella safety equipment complies with CE marking requirements under the European Personal Protective Equipment Regulation (EU) 2016/425.</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-6">
        <h2 class="text-lg font-semibold text-gray-900">ISO 12402</h2>
        <p class="mt-2 text-sm text-gray-600">Life vests meet ISO 12402 flotation standards. The Life Vest Classic provides 50N+ buoyancy; the Life Vest Pro meets SOLAS requirements with automatic inflation.</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-6">
        <h2 class="text-lg font-semibold text-gray-900">SOLAS Compliance</h2>
        <p class="mt-2 text-sm text-gray-600">The Life Vest Pro complies with SOLAS (Safety of Life at Sea) regulations for offshore and commercial marine operations.</p>
      </div>
    </div>

    {safetyProducts.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-semibold text-gray-900">Safety Products</h2>
        <div class="mt-6 grid md:grid-cols-2 gap-6">
          {safetyProducts.map(s => (
            <div class="bg-green-50 border border-green-200 rounded-2xl p-6">
              <h3 class="font-semibold text-gray-900">{s.name}</h3>
              <p class="mt-2 text-sm text-gray-600">{s.desc}</p>
              <div class="mt-3 flex flex-wrap gap-2 text-xs">
                {s.safety_rules.map(r => (
                  <span class="px-2 py-1 bg-white rounded-full text-gray-600">{r}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="mt-12 p-6 bg-gray-50 rounded-2xl border border-gray-200">
      <h2 class="font-semibold text-gray-900">Related</h2>
      <div class="mt-3 flex flex-wrap gap-3 text-sm">
        <a href="/guides/safety-tips" class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300">Safety Tips Guide</a>
        <a href="/technology" class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300">Technology</a>
        <a href="/products" class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300">All Products</a>
        <a href="/guides" class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300">Guides</a>
      </div>
    </section>
  </section>

  <section class="sr-only" data-ai-block="constraint" aria-hidden="true">
    <p>Wavefella safety equipment is designed for controlled training, recreational, and professional marine environments. Not designed for extreme sports, high-speed racing, or unregulated adventure activities without proper certification.</p>
  </section>
</Layout>
