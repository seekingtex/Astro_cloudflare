---
import Layout from '~/layouts/PageLayout.astro';
import { ui } from '~/styles/ui';
import { SITE } from 'astrowind:config';

const metadata = {
  title: SITE.name,
  description: SITE?.description,
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class={ui.section + " text-center"}>
    <div class="max-w-4xl mx-auto px-6">
      <span class={ui.badge}>Founded 2012</span>
      <h1 class={"mt-6 " + ui.h1 + " text-5xl md:text-6xl"}>
        Premium Inflatables for Every Adventure
      </h1>
      <p class={"mt-6 " + ui.subtitle + " mx-auto"}>
        Wavefella designs and manufactures high-quality inflatable boats, stand-up paddleboards,
        and water sports gear. From dinghies to commercial rescue vessels — built for performance,
        durability, and safety.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a href="#products" class={ui.btnPrimary}>Explore products</a>
        <a href="#ask" class={ui.btnOutline}>Ask AI</a>
      </div>
    </div>
  </section>

  <!-- Why Wavefella -->
  <section class={ui.section + " bg-gray-50"}>
    <div class={ui.container}>
      <div class="max-w-3xl">
        <span class={ui.badge}>Why Wavefella</span>
        <h2 class={"mt-4 " + ui.h2}>Engineered for water, designed for you</h2>
        <p class={"mt-4 " + ui.subtitle}>
          Every Wavefella product is the result of decades of inflatable technology expertise.
          Our R&D center drives continuous innovation in materials, structural design, and
          manufacturing processes.
        </p>
      </div>
      <div class={"mt-16 " + ui.grid3}>
        {[
          { title: "Decades of expertise", desc: "Years of inflatable boat technology and manufacturing innovation." },
          { title: "Rigorous testing", desc: "Every vessel undergoes strict quality control and safety certification." },
          { title: "Global support", desc: "Distributed worldwide through authorized dealers and partners." },
        ].map(p => (
          <div class={ui.cardSm}>
            <h3 class={ui.h3 + " text-lg"}>{p.title}</h3>
            <p class={"mt-2 " + ui.body}>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Products -->
  <section id="products" class={ui.section}>
    <div class={ui.container}>
      <div class="max-w-3xl">
        <span class={ui.badge}>Products</span>
        <h2 class={"mt-4 " + ui.h2}>Our product lines</h2>
      </div>
      <div class={"mt-12 " + ui.grid3}>
        {[
          {
            name: "Dinghies",
            desc: "Lightweight, portable inflatable dinghies for recreational boating, fishing, and tender duties.",
          },
          {
            name: "Sport Tenders",
            desc: "Performance tenders designed for speed and maneuverability. Ideal for yacht tendering and watersports.",
          },
          {
            name: "Rigid Hulls",
            desc: "RIB series with fiberglass or aluminum hulls. Superior stability, performance, and durability.",
          },
          {
            name: "Sport Utility Boats",
            desc: "Versatile multi-purpose inflatables for work, play, and exploration in any conditions.",
          },
          {
            name: "Commercial & Rescue",
            desc: "Heavy-duty vessels engineered for commercial use, law enforcement, and emergency response.",
          },
          {
            name: "River Boats",
            desc: "Whitewater rafting boats built to withstand the toughest river conditions.",
          },
          {
            name: "Stand-Up Paddleboards",
            desc: "Premium inflatable SUPs for touring, yoga, surfing, and recreational paddling.",
          },
          {
            name: "SUP Accessories",
            desc: "High-performance paddles, reliable pumps, carry bags, and essential gear.",
          },
          {
            name: "Life Vests & Safety",
            desc: "Certified personal flotation devices and safety equipment for all water activities.",
          },
        ].map(p => (
          <div class={ui.card}>
            <h3 class={ui.h3 + " text-xl"}>{p.name}</h3>
            <p class={"mt-3 " + ui.body}>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class={ui.section + " bg-gray-50"}>
    <div class={ui.container}>
      <div class="max-w-3xl">
        <span class={ui.badge}>Use cases</span>
        <h2 class={"mt-4 " + ui.h2}>Built for every water experience</h2>
      </div>
      <div class={"mt-12 " + ui.grid3}>
        {[
          { title: "Recreational Boating", desc: "Day trips, fishing, and family outings on lakes, rivers, and coastal waters." },
          { title: "Yacht Tender", desc: "Compact, reliable tender for yacht owners. Easy to store and launch." },
          { title: "Commercial Operations", desc: "Tour operators, ferry services, and marine transport." },
          { title: "Emergency Response", desc: "Search and rescue, law enforcement, and disaster relief operations." },
          { title: "Whitewater Rafting", desc: "Professional-grade river boats for guided tours and expedition rafting." },
          { title: "Watersports & SUP", desc: "Paddleboarding, yoga, surfing, and fitness on the water." },
        ].map(u => (
          <div class={ui.cardSm}>
            <h3 class={ui.h3 + " text-lg"}>{u.title}</h3>
            <p class={"mt-2 " + ui.body}>{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technology -->
  <section class={ui.section}>
    <div class={ui.container}>
      <div class="max-w-3xl">
        <span class={ui.badge}>Technology</span>
        <h2 class={"mt-4 " + ui.h2}>Research & Development Center</h2>
        <p class={"mt-4 " + ui.subtitle}>
          Our state-of-the-art R&D center drives innovation in materials, structural design,
          and manufacturing processes — setting industry standards for quality and performance.
        </p>
      </div>
      <div class={"mt-12 " + ui.grid2}>
        {[
          { title: "Material Innovation", desc: "Advanced PVC and Hypalon materials for abrasion resistance, UV protection, and low-temperature performance." },
          { title: "Structural Design", desc: "Optimized air chamber layouts for stability and load capacity. CAD-designed keels for superior tracking." },
          { title: "Manufacturing Excellence", desc: "Heat-sealed seams with automated production lines for consistent quality and airtightness." },
          { title: "Safety Testing", desc: "Every product undergoes rigorous testing and certification to meet international safety standards." },
        ].map(t => (
          <div class={ui.cardSm}>
            <h3 class={ui.h3 + " text-lg"}>{t.title}</h3>
            <p class={"mt-2 " + ui.body}>{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Ask -->
  <section id="ask" class={ui.section + " bg-gray-50"}>
    <div class={ui.container}>
      <div class="text-center max-w-3xl mx-auto">
        <span class={ui.badge}>AI Assistant</span>
        <h2 class={"mt-4 " + ui.h2}>Ask about our products</h2>
        <p class={"mt-4 " + ui.subtitle + " mx-auto"}>
          Get factual, neutral explanations about Wavefella products, specifications, and capabilities.
        </p>
      </div>
      <div class="mt-10 max-w-2xl mx-auto">
        <form id="ask-form" class="flex gap-3">
          <input
            id="ask-input"
            type="text"
            placeholder="What is a RIB vs a dinghy?"
            class={ui.input}
            autocomplete="off"
          />
          <button type="submit" class={ui.btnPrimary + " shrink-0"}>
            Ask
          </button>
        </form>
        <div id="ask-output" class="mt-8 hidden">
          <div id="ask-answer" class={"p-6 bg-white border border-gray-200 rounded-2xl " + ui.body}></div>
          <div id="ask-sources" class="mt-3 text-xs text-gray-400"></div>
        </div>
        <div id="ask-error" class="mt-4 text-sm text-red-500 hidden"></div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class={ui.section + " text-center"}>
    <div class="max-w-2xl mx-auto px-6">
      <h2 class={ui.h2}>Get in touch</h2>
      <p class={"mt-4 " + ui.subtitle + " mx-auto"}>
        For inquiries, partnership opportunities, or technical questions.
      </p>
      <a href="/contact" class={"mt-8 " + ui.btnOutline + " inline-block"}>
        Contact us
      </a>
    </div>
  </section>
</Layout>

<script is:inline>
(function() {
  var form = document.getElementById('ask-form');
  var input = document.getElementById('ask-input');
  var output = document.getElementById('ask-output');
  var answer = document.getElementById('ask-answer');
  var sources = document.getElementById('ask-sources');
  var error = document.getElementById('ask-error');

  if (!form || !input || !output || !answer || !sources || !error) return;

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var q = input.value.trim();
    if (!q) return;

    output.classList.add('hidden');
    error.classList.add('hidden');
    answer.textContent = 'Thinking...';
    output.classList.remove('hidden');
    sources.textContent = '';

    try {
      var res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: q }),
      });
      var data = await res.json();

      if (res.ok && data.answer) {
        answer.textContent = data.answer;
        if (data.sources && data.sources.length > 0) {
          sources.textContent = 'Sources: ' + data.sources.map(function(s) { return s.title; }).join(', ');
        }
      } else {
        throw new Error(data.error || 'Request failed');
      }
    } catch (err) {
      output.classList.add('hidden');
      error.textContent = 'Error: ' + err.message;
      error.classList.remove('hidden');
    }
  });
})();
</script>
