---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');

const token = readTokenFromCookies(Astro.cookies);
---
<AdminLayout title="关联 GitHub" active="dashboard" username={verified?.username}>
  <div class="max-w-xl">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6">
      <h1 class="text-xl font-semibold">关联 GitHub Personal Access Token</h1>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
        用于向 <code class="font-mono">theworkvigour/astro_Tina-CMS</code> 推送内容改动。
        不会持久化到任何文件或数据库,只会加密保存在你的浏览器 cookie 中。
      </p>

      <div class="mt-4 rounded-md bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-3 text-sm">
        <div class="font-medium mb-1">如何生成 Token</div>
        <ol class="list-decimal list-inside space-y-1 text-gray-600 dark:text-gray-400">
          <li>访问 <a href="https://github.com/settings/tokens" target="_blank" rel="noopener" class="text-blue-600 hover:underline">github.com/settings/tokens</a></li>
          <li>点 <strong>Generate new token</strong> → 选 <strong>Fine-grained token</strong></li>
          <li>Resource owner 选 <code class="font-mono">theworkvigour</code></li>
          <li>Repository access → Only select repositories → <code class="font-mono">astro_Tina-CMS</code></li>
          <li>Permissions → Repository permissions:
            <ul class="list-disc list-inside ml-5">
              <li><strong>Contents</strong>: Read and write</li>
              <li><strong>Metadata</strong>: Read-only (默认)</li>
            </ul>
          </li>
          <li>点 <strong>Generate token</strong>,复制(只显示一次)</li>
        </ol>
      </div>

      <form id="token-form" class="mt-6 space-y-4">
        <div>
          <label for="token" class="block text-sm font-medium mb-1">Personal Access Token</label>
          <input
            type="password"
            id="token"
            name="token"
            required
            placeholder="github_pat_xxx 或 ghp_xxx"
            autocomplete="off"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
          />
        </div>
        <div id="message" class="hidden rounded-md p-3 text-sm"></div>
        <div class="flex items-center gap-3">
          <button
            type="submit"
            id="submit-btn"
            class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md disabled:opacity-50"
          >验证并保存</button>
          {token && (
            <button
              type="button"
              id="clear-btn"
              class="px-4 py-2 bg-white hover:bg-gray-50 dark:bg-gray-800 dark:hover:bg-gray-700 text-sm font-medium border border-gray-300 dark:border-gray-700 rounded-md text-red-600 dark:text-red-400"
            >清除已保存的 Token</button>
          )}
          <a href="/keystatic" class="text-sm text-gray-500 hover:underline">返回 Dashboard</a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  (function () {
    const form = document.getElementById('token-form');
    if (!form) return;
    const msg = document.getElementById('message');
    const btn = document.getElementById('submit-btn');
    const clearBtn = document.getElementById('clear-btn');

    function showMessage(text, type) {
      msg.className = 'rounded-md p-3 text-sm ' +
        (type === 'error'
          ? 'bg-red-50 dark:bg-red-950/40 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-900'
          : 'bg-green-50 dark:bg-green-950/40 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-900');
      msg.textContent = text;
      msg.classList.remove('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const token = document.getElementById('token').value.trim();
      if (!token) {
        showMessage('请输入 Token', 'error');
        return;
      }
      btn.disabled = true;
      btn.textContent = '验证中...';
      msg.classList.add('hidden');
      try {
        const res = await fetch('/api/admin/save-token', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token }),
        });
        const data = await res.json();
        if (!res.ok || !data.success) {
          showMessage(data.error || '验证失败', 'error');
          return;
        }
        showMessage('Token 已保存,正在跳转...', 'success');
        setTimeout(() => { window.location.href = '/keystatic'; }, 600);
      } catch (err) {
        showMessage('网络错误,请重试', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = '验证并保存';
      }
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', async () => {
        if (!confirm('确定清除已保存的 Token?清除后访问 /keystatic/posts 等页面会要求重新输入。')) return;
        clearBtn.disabled = true;
        try {
          const res = await fetch('/api/admin/save-token', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'clear' }),
          });
          const data = await res.json();
          if (data.success) {
            window.location.reload();
          } else {
            showMessage(data.error || '清除失败', 'error');
            clearBtn.disabled = false;
          }
        } catch {
          showMessage('网络错误', 'error');
          clearBtn.disabled = false;
        }
      });
    }
  })();
</script>
